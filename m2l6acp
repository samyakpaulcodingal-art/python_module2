# --- Step 1: Import the turtle library ---
import turtle

# --- Step 2: Set up the screen and the turtle ---
screen = turtle.Screen()
screen.title("Drawing a Square")

# Create our turtle pen and name it 'my_turtle'
my_turtle = turtle.Turtle()
my_turtle.shape("turtle")  # Changes the cursor icon into a cute turtle!
my_turtle.color("blue")    # Changes the pen color to blue

# --- Step 3: Use a loop to draw the 4 sides of the square ---
for i in range(4):
    my_turtle.forward(100)  # Move forward by 100 pixels
    my_turtle.left(90)     # Turn left by 90 degrees

# --- Step 4: Finish the drawing ---
# This keeps the graphics window open until you manually click the 'X' close button
turtle.done()
